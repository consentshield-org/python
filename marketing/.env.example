# ConsentShield marketing site — environment variables.
#
# All variables are optional in local dev. The absence of a Turnstile
# key falls back to the Cloudflare Turnstile always-pass test pair so
# the contact form remains interactive. Resend falls back to a no-op
# (logged server-side); Sentry falls back to a disabled client.
#
# Copy this to .env.local for local development. Production secrets are
# set via the Vercel project UI — never committed.

# ─── Cloudflare Turnstile (human-verification on the contact form) ────
# Dev defaults (Cloudflare's always-pass test pair):
#   site key   = 1x00000000000000000000AA
#   secret key = 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Resend (transactional email for contact form submissions) ────────
# When unset, the contact form accepts the submission and logs it to
# the server console instead of emailing. Useful for local smoke tests.
RESEND_API_KEY=
# Destination for incoming contact-form leads. Defaults to
# hello@consentshield.in if unset.
CONTACT_INBOX=

# ─── Sentry (client + server error reporting, PII-stripped) ───────────
# Unset → Sentry initialisation no-ops. Production DSN goes in the
# Vercel project env.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Forbidden on this project (see scripts/check-env-isolation.ts) ───
# Do NOT set any of the following on the marketing Vercel project — the
# prebuild check will fail the build.
#   MASTER_ENCRYPTION_KEY, DELETION_CALLBACK_SECRET,
#   RAZORPAY_WEBHOOK_SECRET, RAZORPAY_KEY_SECRET,
#   SUPABASE_SERVICE_ROLE_KEY, SUPABASE_JWT_SECRET,
#   anything starting with ADMIN_
