# ConsentShield — Environment Variables
# Copy to .env.local and fill in values. NEVER commit .env.local.
# Vercel deploys: set the same values via `vercel env add <NAME> production preview`.

# Supabase — client-safe
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key>
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CDN_URL=https://cdn.consentshield.in

# Supabase — server-side only (NEVER NEXT_PUBLIC_)
# Used only for migrations and emergency admin. Per ADR-0009, application
# code never reads this at runtime — all mutations go through scoped-role
# RPCs under the user's anon/authenticated JWT.
SUPABASE_SERVICE_ROLE_KEY=<service role key>

# Encryption
MASTER_ENCRYPTION_KEY=<32-byte hex — per-org key derivation base>
DELETION_CALLBACK_SECRET=<32-byte hex — HMAC signing for deletion callbacks>

# Razorpay — optional in dev; billing features disabled without these
RAZORPAY_KEY_ID=<key id>
RAZORPAY_KEY_SECRET=<key secret>
RAZORPAY_WEBHOOK_SECRET=<webhook secret>

# Resend
RESEND_API_KEY=<resend api key>
RESEND_FROM=onboarding@resend.dev

# Cloudflare — used by banner-publish route (KV cache invalidation + grace secret)
CLOUDFLARE_ACCOUNT_ID=<cf account id>
CLOUDFLARE_API_TOKEN=<cf api token — scoped to KV namespace>
CLOUDFLARE_KV_NAMESPACE_ID=<kv namespace id>

# Turnstile
# Dev: use the Cloudflare always-pass test keys (site: 1x00000000000000000000AA,
# secret: 1x0000000000000000000000000000000AA). Production refuses to start
# without the real secret — see ADR-0008 Sprint 1.3.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<cf turnstile site key>
TURNSTILE_SECRET_KEY=<cf turnstile secret — server-side only>

# Sentry (optional)
SENTRY_DSN=<sentry dsn>

# ─── Supabase Edge Function secrets (NOT Next.js env) ─────────────────────────
# Set these via `supabase secrets set`, not .env.local:
#   CS_ORCHESTRATOR_ROLE_KEY=<cs_orchestrator password>
# Reason: Supabase reserves the SUPABASE_ prefix, so we use CS_ for custom
# function secrets. The Edge Function refuses to boot without this key
# (no service-role fallback) — see ADR-0009 Phase 3.
