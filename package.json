{
  "name": "consentshield-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["app", "admin", "marketing", "testing", "worker", "packages/*", "tests/e2e"],
  "scripts": {
    "test:rls": "vitest run",
    "test:e2e": "cd tests/e2e && bun run test",
    "test:e2e:smoke": "cd tests/e2e && bun run test:smoke",
    "test:e2e:full": "cd tests/e2e && bun run test:full",
    "test:e2e:partner": "cd tests/e2e && bun run test:partner",
    "test:e2e:controls": "bunx tsx scripts/e2e-verify-controls.ts",
    "test:e2e:report": "cd tests/e2e && bun run report",
    "test:mutation": "bunx tsx scripts/run-mutation-suite.ts",
    "test:mutation:report-only": "bunx tsx scripts/run-mutation-suite.ts --skip-runs"
  },
  "devDependencies": {
    "@supabase/supabase-js": "2.103.0",
    "@types/node": "20.19.39",
    "dotenv": "17.4.2",
    "jszip": "3.10.1",
    "postgres": "3.4.9",
    "prettier": "3.8.2",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
}
